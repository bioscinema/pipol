setwd("D:/studies/liangliang/Code/PIPoL")
devtools::load_all()
library(phyloseq)
library(dplyr)
library(PIPoL)
load("../Real_Data/ibd_16s_negative.RData")
otu_matrix <- as(physeq@otu_table, "matrix")
sample.names <- colnames(as.data.frame(otu_matrix))
NC <- ifelse(grepl("blank", sample.names, ignore.case = TRUE),
"Control",
"Biological")
metadata <- data.frame(sampleID = sample.names, NC = NC)
rownames(metadata) <- metadata$sampleID
metadata$sampleID <- NULL
sample_data(physeq) <- sample_data(metadata)
library(phyloseq)
library(dplyr)
library(PIPoL)
load("../Real_Data/ibd_16s_negative.RData")
otu_matrix <- as(physeq@otu_table, "matrix")
sample.names <- colnames(as.data.frame(otu_matrix))
NC <- ifelse(grepl("blank", sample.names, ignore.case = TRUE),
"Control",
"Biological")
metadata <- data.frame(sampleID = sample.names, NC = NC)
rownames(metadata) <- metadata$sampleID
metadata$sampleID <- NULL
sample_data(physeq) <- sample_data(metadata)
decon_res <- decontamination(
physeq = physeq,
outcome_var = "NC",
label = "Control",
tau = "Genus",
alpha = 0.05,
gamma_weighted = 0.05,
gamma_unweighted = 0.05
)
decon_res$plot
decon_res <- decontamination(
physeq = physeq,
outcome_var = "NC",
label = "Control",
tau = "Genus",
alpha = 0.05,
gamma_weighted = 0.05,
gamma_unweighted = 0.05
)
decon_res$plot
enrich_res <- enrichment_prevalence(
physeq = physeq,
outcome_var = "NC",
group = "Control",
tau_level = "Genus",
alpha = 0.05,
min_prevalence = 0.05
)
enrich_res$plot_enrichment
enrich_res$plot_prev_enrich
enrich_res$plot_abund_enrich
enrich_res$plot_prev_abund
library(patchwork)
pC <- decon_res$plot +
labs(tag = "C") +
theme(
plot.tag = element_text(size = 16, face = "bold"),
plot.tag.position = c(0, 1)
)
enrich_res <- enrichment_prevalence(
physeq = physeq,
outcome_var = "NC",
group = "Control",
tau_level = "Genus",
alpha = 0.05,
min_prevalence = 0.05
)
enrich_res$plot_enrichment
enrich_res$plot_prev_enrich
enrich_res$plot_abund_enrich
enrich_res$plot_prev_abund
