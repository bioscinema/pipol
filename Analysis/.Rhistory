as.data.frame()
contam <- unique(contam_df$Genus) # 定义 contam
### 2. 运行分析
# --- 1. 运行分析并提取结果 ---
core_res <- decontamination(
physeq = physeq,
outcome_var = "GroupLabel",
label = "blank",
tau = "Genus",
alpha = 0.05,
gamma_weighted = 0.1,
gamma_unweighted = 0.1
)
tt <- core_res$table
# --- 2. 补全缺失的绘图元数据 ---
# 必须手动找回流行度、丰度和属名分类
tt$TAXprev <- rowSums(otu_table(physeq) > 0)[match(tt$OTU, taxa_names(physeq))]
tt$TAXsums <- taxa_sums(physeq)[match(tt$OTU, taxa_names(physeq))]
tax_df <- as.data.frame(tax_table(physeq))
tt$Genus <- tax_df$Genus[match(tt$OTU, rownames(tax_df))]
# 定义参考分类 Group
tt$Group <- "Ambiguous"
tt$Group[tt$Genus %in% oral & !tt$Genus %in% contam] <- "Oral"
tt$Group[tt$Genus %in% contam & !tt$Genus %in% oral] <- "Contaminant"
# 关键：创建分面变量
tt$Prevalence_Group <- cut(as.numeric(tt$TAXprev),
breaks = c(-Inf, 2, 5, 10, Inf),
labels = c("2", "3-5", "6-10", "11+"))
# --- 3. 绘图并强制应用分层 ---
p_ref <- plot_reference_scatter(
results_df = tt,
score_x = "CoexistZ",      # 使用 Z-score 轴
score_y = "CoenrichZ",
group_col = "Group",
abundance_col = "TAXsums",
prevalence_col = "Prevalence_Group",
facet = TRUE,              # 确保开启
prevalence_bins = NULL,
alpha = 0.5
)
# --- 4. 样式深度定制 (对齐 Fig A) ---
p_ref <- p_ref +
# 强制添加分面层，解决“没分层”的问题
ggplot2::facet_grid(~Prevalence_Group) +
# 调整点的大小，体现丰度差异
ggplot2::scale_size_area(max_size = 12) +
# 配色方案
ggplot2::scale_color_manual(
values = c("Oral" = "blue", "Contaminant" = "red", "Ambiguous" = "gray80"),
name = "Reference\nClassification"
) +
# 坐标轴自适应 Z-score 范围
ggplot2::labs(x = "Score (Coexists Z-score)", y = "Score (Coenrich Z-score)") +
ggplot2::theme_light() +
ggplot2::theme(
strip.background = element_rect(fill = "gray90"), # 分面条背景变灰
strip.text = element_text(color = "black", face = "bold", size = 11)
) +
# 隐藏 size 图例，保持简洁
ggplot2::guides(color = guide_legend(override.aes = list(size = 4, alpha = 1)), size = "none")
print(p_ref)
# 1. 尺度转换：将 Z-score 映射到 0-1 概率空间
tt$Coexist_mapped <- pnorm(tt$CoexistZ)
tt$Coenrich_mapped <- pnorm(tt$CoenrichZ)
# 2. 重新绘图
p_final <- plot_reference_scatter(
results_df = tt,
score_x = "Coexist_mapped",
score_y = "Coenrich_mapped",
group_col = "Group",
abundance_col = "TAXsums",
prevalence_col = "Prevalence_Group",
facet = TRUE,
alpha = 0.5
) +
# 限制点的大小映射，防止大点遮盖小点
ggplot2::scale_size_area(max_size = 10) +
# 恢复 0-1 的坐标轴显示
ggplot2::scale_x_continuous(breaks = seq(0, 1, 0.25), limits = c(0, 1)) +
ggplot2::scale_y_continuous(breaks = seq(0, 1, 0.25), limits = c(0, 1)) +
ggplot2::scale_color_manual(values = c("Oral" = "blue", "Contaminant" = "red", "Ambiguous" = "gray80")) +
ggplot2::labs(x = "Score (Coexists)", y = "Score (Coenrich)") +
ggplot2::theme_light()
print(p_final)
# --- 1. 尺度转换：将 Z-score 映射到 0-1 概率空间 ---
tt$CoexistProb <- pnorm(tt$CoexistZ)
tt$CoenrichProb <- pnorm(tt$CoenrichZ)
# --- 2. 核心绘图调用 ---
p_ref <- plot_reference_scatter(
results_df = tt,
score_x = "CoexistProb",      # 使用转换后的概率轴
score_y = "CoenrichProb",
group_col = "Group",
abundance_col = "TAXsums",    # 恢复点的大小映射
prevalence_col = "Prevalence_Group", # 使用刚才切分好的 "2", "3-5" 等
facet = TRUE,                 # 开启分面
prevalence_bins = NULL,       # 设为 NULL，防止函数内部二次切割
n_prevalence_bins = NULL,
alpha = 0.5
)
# --- 3. 强制“补刀”分层逻辑与样式细节 ---
p_ref <- p_ref +
# 关键：手动强制分面，确保万无一失
ggplot2::facet_grid(~Prevalence_Group) +
# 对齐点的大小，防止大气泡遮挡小点
ggplot2::scale_size_area(max_size = 10) +
# 对齐 0-1 坐标轴刻度
ggplot2::scale_x_continuous(breaks = seq(0, 1, 0.25), limits = c(0, 1)) +
ggplot2::scale_y_continuous(breaks = seq(0, 1, 0.25), limits = c(0, 1)) +
# 对齐颜色与标题
ggplot2::scale_color_manual(
values = c("Oral" = "blue", "Contaminant" = "red", "Ambiguous" = "gray80"),
name = "Reference\nClassification"
) +
ggplot2::labs(x = "Score (Coexists)", y = "Score (Coenrich)") +
# 深度对齐主题（带网格线的 light 风格）
ggplot2::theme_light() +
ggplot2::theme(
strip.background = element_rect(fill = "gray90"), # 灰色分面条
strip.text = element_text(color = "black", face = "bold", size = 11),
panel.grid.minor = element_line(color = "white")
) +
ggplot2::guides(
color = guide_legend(override.aes = list(size = 4, alpha = 1)),
size = "none" # 隐藏 size 图例以匹配原图
)
print(p_ref)
### 1. 加载参考数据库 (这一步必须运行，否则没有 Oral 标签)
# 请确保这些文件在你的当前工作目录下
contam_database <- read.csv("../Real_Data/contamination_database.csv")
oral_database <- read.csv("../Real_Data/oral_database.csv")
HOMD <- read.csv("../Real_Data/homd_taxonomy_table.csv")
# 提取属名列表并定义 oral 和 contam 变量
oral_cult <- unique(HOMD$Genus[HOMD$Status %in% c('Named','Unnamed')])
oral_vis <- unique(oral_database$Genus)
oral <- unique(c(oral_cult, oral_vis)) # 定义 oral
contam_df <- contam_database %>%
group_by(Genus) %>%
mutate(numberstudies = length(unique(Reference))) %>%
as.data.frame()
contam <- unique(contam_df$Genus) # 定义 contam
### 2. 运行分析
# --- 1. 运行分析并提取结果 ---
core_res <- decontamination(
physeq = physeq,
outcome_var = "GroupLabel",
label = "blank",
tau = "Genus",
alpha = 0.05,
gamma_weighted = 0.1,
gamma_unweighted = 0.1
)
tt <- core_res$table
# --- 2. 补全缺失的绘图元数据 ---
# 必须手动找回流行度、丰度和属名分类
tt$TAXprev <- rowSums(otu_table(physeq) > 0)[match(tt$OTU, taxa_names(physeq))]
tt$TAXsums <- taxa_sums(physeq)[match(tt$OTU, taxa_names(physeq))]
tax_df <- as.data.frame(tax_table(physeq))
tt$Genus <- tax_df$Genus[match(tt$OTU, rownames(tax_df))]
# 定义参考分类 Group
tt$Group <- "Ambiguous"
tt$Group[tt$Genus %in% oral & !tt$Genus %in% contam] <- "Oral"
tt$Group[tt$Genus %in% contam & !tt$Genus %in% oral] <- "Contaminant"
# 关键：创建分面变量
tt$Prevalence_Group <- cut(as.numeric(tt$TAXprev),
breaks = c(-Inf, 2, 5, 10, Inf),
labels = c("2", "3-5", "6-10", "11+"))
# --- 3. 绘图并强制应用分层 ---
p_ref <- plot_reference_scatter(
results_df = tt,
score_x = "CoexistZ",      # 使用 Z-score 轴
score_y = "CoenrichZ",
group_col = "Group",
abundance_col = "TAXsums",
prevalence_col = "Prevalence_Group",
facet = TRUE,              # 确保开启
prevalence_bins = NULL,
alpha = 0.5
)
# --- 4. 样式深度定制 (对齐 Fig A) ---
p_ref <- p_ref +
# 强制添加分面层，解决“没分层”的问题
ggplot2::facet_grid(~Prevalence_Group) +
# 调整点的大小，体现丰度差异
ggplot2::scale_size_area(max_size = 12) +
# 配色方案
ggplot2::scale_color_manual(
values = c("Oral" = "blue", "Contaminant" = "red", "Ambiguous" = "gray80"),
name = "Reference\nClassification"
) +
# 坐标轴自适应 Z-score 范围
ggplot2::labs(x = "Score (Coexists Z-score)", y = "Score (Coenrich Z-score)") +
ggplot2::theme_light() +
ggplot2::theme(
strip.background = element_rect(fill = "gray90"), # 分面条背景变灰
strip.text = element_text(color = "black", face = "bold", size = 11)
) +
# 隐藏 size 图例，保持简洁
ggplot2::guides(color = guide_legend(override.aes = list(size = 4, alpha = 1)), size = "none")
print(p_ref)
# --- 1. 优化流行度分层 (让点在不同面板分布更均匀) ---
# 这里的数字 (5, 20, 50) 请根据你实际的 TAXprev 分布灵活调整
tt$Prevalence_Group <- cut(
as.numeric(tt$TAXprev),
breaks = c(-Inf, 5, 20, 50, Inf),
labels = c("<5", "5-20", "20-50", "50+")
)
# --- 2. 优化分数映射 (保留更多 Z-score 的差异细节) ---
# 如果直接 pnorm 太挤，可以尝试手动线性缩放到 0-1
rescale_01 <- function(x) (x - min(x)) / (max(x) - min(x))
tt$Coexist_mapped <- rescale_01(tt$CoexistZ)
tt$Coenrich_mapped <- rescale_01(tt$CoenrichZ)
# --- 3. 终极绘图调用 ---
p_final <- plot_reference_scatter(
results_df = tt,
score_x = "Coexist_mapped",
score_y = "Coenrich_mapped",
group_col = "Group",
abundance_col = "TAXsums",
prevalence_col = "Prevalence_Group",
facet = TRUE,
alpha = 0.5
)
# --- 4. 样式精调 (深度对齐原图视觉感) ---
p_final <- p_final +
# 手动强制分面
ggplot2::facet_grid(~Prevalence_Group) +
# 调整点的大小，防止大气泡太满
ggplot2::scale_size_area(max_size = 10) +
# 恢复 0-1 坐标轴并使用更细的刻度
ggplot2::scale_x_continuous(breaks = seq(0, 1, 0.25)) +
ggplot2::scale_y_continuous(breaks = seq(0, 1, 0.25)) +
# 对齐颜色
ggplot2::scale_color_manual(
values = c("Oral" = "blue", "Contaminant" = "red", "Ambiguous" = "#C0C0C0"),
name = "Reference\nClassification"
) +
# 使用深灰背景主题增强对比
ggplot2::theme_dark() +
ggplot2::theme(
panel.background = element_rect(fill = "#EBEBEB"), # 浅灰背景
panel.grid.major = element_line(color = "white", size = 0.5), # 白色粗网格
panel.grid.minor = element_line(color = "white", size = 0.2), # 白色细网格
strip.background = element_rect(fill = "gray80"),
strip.text = element_text(color = "black", face = "bold")
) +
ggplot2::labs(x = "Score (Coexists)", y = "Score (Coenrich)") +
ggplot2::guides(color = guide_legend(override.aes = list(size = 4, alpha = 1)), size = "none")
print(p_final)
tt$CoexistProb <- pnorm(tt$CoexistZ)
tt$CoenrichProb <- pnorm(tt$CoenrichZ)
p_ref <- plot_reference_scatter(
results_df = tt,
score_x = "CoexistProb",
score_y = "CoenrichProb",
group_col = "Group",
abundance_col = "TAXsums",
prevalence_col = "Prevalence_Group",
facet = TRUE,
prevalence_bins = NULL,
n_prevalence_bins = NULL,
alpha = 0.5
)
p_ref <- p_ref +
ggplot2::facet_grid(~Prevalence_Group) +
ggplot2::scale_size_area(max_size = 10) +
ggplot2::scale_x_continuous(breaks = seq(0, 1, 0.25), limits = c(0, 1)) +
ggplot2::scale_y_continuous(breaks = seq(0, 1, 0.25), limits = c(0, 1)) +
ggplot2::scale_color_manual(
values = c("Oral" = "blue", "Contaminant" = "red", "Ambiguous" = "gray80"),
name = "Reference\nClassification"
) +
ggplot2::labs(x = "Score (Coexists)", y = "Score (Coenrich)") +
ggplot2::theme_light() +
ggplot2::theme(
strip.background = element_rect(fill = "gray90"),
strip.text = element_text(color = "black", face = "bold", size = 11),
panel.grid.minor = element_line(color = "white")
) +
ggplot2::guides(
color = guide_legend(override.aes = list(size = 4, alpha = 1)),
size = "none"
)
print(p_ref)
# --- 1. 还原原始脚本的 Z -> P 转换逻辑 ---
# 原始脚本认为分数越小越像污染物，所以我们取单尾概率
tt$coexists.p <- stats::pnorm(tt$CoexistZ, lower.tail = FALSE)
tt$coenrich.p <- stats::pnorm(tt$CoenrichZ, lower.tail = FALSE)
# --- 2. 流行度分箱 (严格对齐原图的 2, 3-5, 6-10, 11+) ---
tt$Prevalence_Group <- cut(
as.numeric(tt$TAXprev),
breaks = c(0, 2, 5, 10, Inf),
labels = c("2", "3-5", "6-10", "11+")
)
# --- 3. 绘图调用 ---
p_ref <- plot_reference_scatter(
results_df = tt,
score_x = "coexists.p",
score_y = "coenrich.p",
group_col = "Group",
abundance_col = "TAXsums",
prevalence_col = "Prevalence_Group",
facet = TRUE,
alpha = 0.5
)
# --- 4. 样式深度对齐 (还原 Fig A 的质感) ---
p_ref <- p_ref +
ggplot2::facet_grid(~Prevalence_Group) +
# 调整点的大小，确保高丰度属（Genus）是大球
ggplot2::scale_size_area(max_size = 12) +
# 恢复 0-1 坐标轴
ggplot2::scale_x_continuous(breaks = seq(0, 1, 0.25), limits = c(0, 1)) +
ggplot2::scale_y_continuous(breaks = seq(0, 1, 0.25), limits = c(0, 1)) +
# 颜色方案
ggplot2::scale_color_manual(
values = c("Oral" = "blue", "Contaminant" = "red", "Ambiguous" = "gray80"),
name = "Reference\nClassification"
) +
ggplot2::labs(x = "Score (Coexists)", y = "Score (Coenrich)") +
# 使用 light 主题配合网格线
ggplot2::theme_light() +
ggplot2::theme(
strip.background = element_rect(fill = "gray90"),
strip.text = element_text(color = "black", face = "bold"),
panel.grid.minor = element_line(color = "white")
) +
ggplot2::guides(color = guide_legend(override.aes = list(size = 4, alpha = 1)), size = "none")
print(p_ref)
tt$CoexistProb <- pnorm(tt$CoexistZ)
tt$CoenrichProb <- pnorm(tt$CoenrichZ)
p_ref <- plot_reference_scatter(
results_df = tt,
score_x = "CoexistProb",
score_y = "CoenrichProb",
group_col = "Group",
abundance_col = "TAXsums",
prevalence_col = "Prevalence_Group",
facet = TRUE,
prevalence_bins = NULL,
n_prevalence_bins = NULL,
alpha = 0.5
)
p_ref <- p_ref +
ggplot2::facet_grid(~Prevalence_Group) +
ggplot2::scale_size_area(max_size = 10) +
ggplot2::scale_x_continuous(breaks = seq(0, 1, 0.25), limits = c(0, 1)) +
ggplot2::scale_y_continuous(breaks = seq(0, 1, 0.25), limits = c(0, 1)) +
ggplot2::scale_color_manual(
values = c("Oral" = "blue", "Contaminant" = "red", "Ambiguous" = "gray80"),
name = "Reference\nClassification"
) +
ggplot2::labs(x = "Score (Coexists)", y = "Score (Coenrich)") +
ggplot2::theme_light() +
ggplot2::theme(
strip.background = element_rect(fill = "gray90"),
strip.text = element_text(color = "black", face = "bold", size = 11),
panel.grid.minor = element_line(color = "white")
) +
ggplot2::guides(
color = guide_legend(override.aes = list(size = 4, alpha = 1)),
size = "none"
)
print(p_ref)
